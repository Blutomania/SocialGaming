; Engine configuration file.
; Generated for Godot 4.x
; https://godotengine.org/

config_version=5

[application]

config/name="Choose Your Mystery"
config/description="AI-powered social murder mystery party game.\nInvestigate, interrogate, and compete to solve the case first."
config/version="0.1.0"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/ui/icon.png"

[autoload]

; Singletons — loaded before the first scene.
; SESSION ANNOTATION: If you add a new autoload, register it here AND
; verify it appears in Project → Project Settings → Autoload in the editor.
GameState="*res://scripts/autoloads/GameState.gd"
ApiClient="*res://scripts/autoloads/ApiClient.gd"
NetworkManager="*res://scripts/autoloads/NetworkManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="forward_plus"
